PORT=3000

# Дополнительные origin для CORS (через запятую). Admin 3001, API 3000, Expo Web 8081 уже разрешены;
# вне production любой http(s)://localhost|127.0.0.1:* тоже разрешён.
# CORS_ORIGINS=https://app.example.com

# Use 127.0.0.1 on Windows if localhost hits the wrong stack (IPv6).
# DATABASE_PORT must match docker-compose host port (default 15432).
# Save this file as LF line endings — CRLF can break DATABASE_PASSWORD.
DATABASE_HOST=127.0.0.1
DATABASE_PORT=15432
DATABASE_USER=neurosync
DATABASE_PASSWORD=neurosync_dev
DATABASE_NAME=neurosync

# Dev only — disable in production; use migrations instead.
DATABASE_SYNC=true
DATABASE_LOGGING=false

S3_BUCKET=neuro-sync-media
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=http://localhost:9000/neuro-sync-media

MEDIA_MAX_FILE_BYTES=104857600

JWT_SECRET=replace-with-long-random-string
JWT_EXPIRES_IN=7d

# Категории онбординга при старте API (идемпотентно). false — не создавать.
SEED_ONBOARDING_CATEGORIES=true

# Демо-уроки: по 2 урока в каждой из 10 категорий сида, 4 слайда (3 + финал). false — не создавать.
SEED_DEMO_LESSONS=true

# MND-Protocol: 6 мастер-стеков, 20 симптомов и lookup-матрица. false — не создавать.
SEED_MND_CONTENT=true

# First super admin (created once if email not in admin_users)
BOOTSTRAP_ADMIN_EMAIL=admin@neurosync.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe_Admin123
