# Скопируй в `.env` в корне `mobile/`. Все переменные `EXPO_PUBLIC_*` встраиваются в JS при сборке.

# База Nest API (порт смотри в backend; для Android-эмулятора часто: http://10.0.2.2:3000)
EXPO_PUBLIC_API_URL=http://localhost:3000

# Если true: сразу открыть приложение без экрана входа (только для разработки)
EXPO_PUBLIC_DEV_BYPASS_AUTH=false
