# PostgreSQL (docker-compose)
POSTGRES_USER=neurosync
POSTGRES_PASSWORD=neurosync_dev
POSTGRES_DB=neurosync

# MinIO (S3-compatible)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_BUCKET=neuro-sync-media
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_FORCE_PATH_STYLE=true
# Public URL for browser / presigned redirects (often same as S3_ENDPOINT in dev)
S3_PUBLIC_BASE_URL=http://localhost:9000/neuro-sync-media

# Backend (NestJS) — copy to backend/.env
DATABASE_HOST=127.0.0.1
DATABASE_PORT=15432
DATABASE_USER=neurosync
DATABASE_PASSWORD=neurosync_dev
DATABASE_NAME=neurosync

S3_BUCKET=neuro-sync-media
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=http://localhost:9000/neuro-sync-media

# Auth: см. backend/.env — JWT_SECRET, BOOTSTRAP_ADMIN_*
